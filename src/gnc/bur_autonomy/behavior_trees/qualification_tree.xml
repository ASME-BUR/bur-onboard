 <root BTCPP_format="4" >
    <BehaviorTree ID="MainTree">
        <SequenceWithMemory>
            <RetryUntilSuccessful num_attempts="6">
                <SubTree ID="GateTask"/>
            </RetryUntilSuccessful>
        </SequenceWithMemory>
    </BehaviorTree>

    <BehaviorTree ID="GateTask">
        <SequenceWithMemory>
            <Sequence>
                <GoToStart/>
            </Sequence>
            <Sequence>
                <GoToGate/>
            </Sequence>
            <Sequence>
                <GoToStart/>
            </Sequence>
        </SequenceWithMemory>
    </BehaviorTree>
 </root>
