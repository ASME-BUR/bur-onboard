 <root BTCPP_format="4" >
    <BehaviorTree ID="MainTree">
        <SequenceWithMemory>
            <RetryUntilSuccessful num_attempts="6">
                <SubTree ID="GateTask"/>
                <SubTree ID="TorpedoTask"/>
                <SubTree ID="OctagonTask"/>
                <SubTree ID="ReturnToStart"/>
            </RetryUntilSuccessful>
        </SequenceWithMemory>
    </BehaviorTree>

    <BehaviorTree ID="GateTask">
        <SequenceWithMemory>
            <GoToGate/>
            <BarrelRoll/>
            <DriveForward/>
        </SequenceWithMemory>
    </BehaviorTree>

    <BehaviorTree ID="TorpedoTask">
        <SequenceWithMemory>
            <GoToTorpedoTarget/>
            <FireTorpedo/>
        </SequenceWithMemory>
    </BehaviorTree>

    <BehaviorTree ID="OctagonTask">
        <SequenceWithMemory>
            <GoToOctagon/>
        </SequenceWithMemory>
    </BehaviorTree>

    <BehaviorTree ID="ReturnToStart">
        <SequenceWithMemory>
            <GoToGate/>
            <GoToStart/>
        </SequenceWithMemory>
    </BehaviorTree>
 </root>
